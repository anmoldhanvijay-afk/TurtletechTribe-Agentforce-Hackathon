    <decisions>
        <name>Check_Debit_Credit</name>
        <label>Check Debit Credit</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Check_For_Saving_Debit</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.DebitCreditIndicator</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Debit</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.FinancialAccountId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.FinancialAccount.Type</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Savings</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_FinancialAccountBalance</targetReference>
            </connector>
            <label>Check For Saving Debit</label>
        </rules>
