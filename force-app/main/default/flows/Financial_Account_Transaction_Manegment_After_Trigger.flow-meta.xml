    <formulas>
        <name>creditFromCredit</name>
        <dataType>Number</dataType>
        <expression>IF(ISNULL({!get_Parent_Account.Total_Available_Amount__c}), 0, 
{!get_Parent_Account.Total_Available_Amount__c}) 
+ 
IF(ISNULL({!$Record.Amount}), 0, {!$Record.Amount})</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>debitFromCredit</name>
        <dataType>Number</dataType>
        <expression>IF(ISNULL({!get_Parent_Account.Total_Available_Amount__c}), 0, 
{!get_Parent_Account.Total_Available_Amount__c}) 
- 
IF(ISNULL({!$Record.Amount}), 0, {!$Record.Amount})</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>savingCredit</name>
        <dataType>Number</dataType>
        <expression>IF(ISNULL({!get_Parent_Account.Total_Available_Amount__c}), 0, 
{!get_Parent_Account.Total_Available_Amount__c}) 
+ 
IF(ISNULL({!$Record.Amount}), 0, {!$Record.Amount})</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>savingDebit</name>
        <dataType>Number</dataType>
        <expression>IF(ISNULL({!get_Parent_Account.Total_Available_Amount__c}), 0, 
{!get_Parent_Account.Total_Available_Amount__c}) 
- 
IF(ISNULL({!$Record.Amount}), 0, {!$Record.Amount})</expression>
        <scale>2</scale>
    </formulas>
