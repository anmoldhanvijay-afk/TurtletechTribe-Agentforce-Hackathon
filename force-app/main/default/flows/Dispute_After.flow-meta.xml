<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>Amount_greater_than_50k</name>
        <label>Amount greater than 50k</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Create_Dispute_Item</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>yes</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.DisputedAmount</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <numberValue>500000.0</numberValue>
                </rightValue>
            </conditions>
            <label>Yes</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>invoiceDate</name>
        <dataType>Date</dataType>
        <expression>DATE(
    VALUE(RIGHT({!$Record.Case.Invoice_Date__c}, 4)),
    CASE(MID({!$Record.Case.Invoice_Date__c}, 4, 3),
        &quot;Jan&quot;, 1, &quot;Feb&quot;, 2, &quot;Mar&quot;, 3, &quot;Apr&quot;, 4,
        &quot;May&quot;, 5, &quot;Jun&quot;, 6, &quot;Jul&quot;, 7, &quot;Aug&quot;, 8,
        &quot;Sep&quot;, 9, &quot;Oct&quot;, 10, &quot;Nov&quot;, 11, &quot;Dec&quot;, 12,
        0
    ),
    VALUE(LEFT({!$Record.Case.Invoice_Date__c}, 2))
)</expression>
    </formulas>
    <interviewLabel>Dispute: After {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Dispute: After</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
