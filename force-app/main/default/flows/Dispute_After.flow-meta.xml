        <locationY>0</locationY>
        <connector>
            <targetReference>Dispute_Item_Chargeback</targetReference>
        </connector>
        <inputAssignments>
            <field>CurrencyIsoCode</field>
            <value>
                <stringValue>INR</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>DisputeId</field>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>DisputedAmount</field>
            <value>
                <elementReference>$Record.DisputedAmount</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
