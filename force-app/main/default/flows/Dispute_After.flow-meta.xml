        <locationY>0</locationY>
        <connector>
            <targetReference>Amount_greater_than_50k</targetReference>
        </connector>
        <filterFormula>CONTAINS({!$Record.Owner:User.Username}, &quot;einstein&quot;)</filterFormula>
        <object>Dispute</object>
        <recordTriggerType>Create</recordTriggerType>
